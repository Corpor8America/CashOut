@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">Spening</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Code" Color="Color.Inherit" Href="https://github.com/yourusername/spening" Target="_blank" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">💰 Spening</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-2 mb-1">Accounts</MudText>
            <MudNavLink Href="/accounts" Icon="@Icons.Material.Filled.Link">Linked Accounts</MudNavLink>
            <MudNavLink Href="/manual-accounts" Icon="@Icons.Material.Filled.AccountBalance">Manual Accounts</MudNavLink>
            
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-4 mb-1">Data</MudText>
            <MudNavLink Href="/transactions" Icon="@Icons.Material.Filled.List">Transactions</MudNavLink>
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.BarChart">Reports</MudNavLink>
            
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-4 mb-1">Merchants</MudText>
            <MudNavLink Href="/merchants" Icon="@Icons.Material.Filled.Store">Merchants &amp; Aliases</MudNavLink>
            
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-4 mb-1">System</MudText>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="pa-8">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-2">
                    <strong>Something went wrong.</strong>
                    <div style="margin-top:0.4rem;font-size:0.85em;opacity:0.8">@ex.Message</div>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
