@page "/settings"
@inject HttpClient Http

<h2>Settings</h2>

@if (_error != null)
{
    <div class="alert-error">@_error</div>
}

@if (_loading)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <table style="max-width:520px">
        <tbody>
            <tr>
                <td><strong>Plaid Environment</strong></td>
                <td>
                    <code>@_plaidEnvironment</code>
                    <span class="text-muted" style="margin-left:0.5rem">
                        (set via <code>PLAID_ENV</code> env var)
                    </span>
                </td>
            </tr>
            <tr>
                <td><strong>Active Year</strong></td>
                <td>
                    <span>@_outputYear</span>
                    <span class="text-muted" style="margin-left:0.5rem">
                        (from most recent transaction)
                    </span>
                </td>
            </tr>
            <tr>
                <td><strong>Version</strong></td>
                <td><code>@_version</code></td>
            </tr>
        </tbody>
    </table>

    @if (_plaidEnvironment == "production")
    {
        <div class="alert-error" style="margin-top:1rem">
            ⚠ Production mode — using real financial data.
        </div>
    }

    @if (_plaidEnvironment == "sandbox")
    {
        <div class="alert-success" style="margin-top:1rem">
            Sandbox mode — safe for testing with Plaid test credentials.
        </div>
    }
}

@code {
    private string _plaidEnvironment = "sandbox";
    private int _outputYear = DateTime.Now.Year;
    private string _version = "—";
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await Http.GetFromJsonAsync<Dictionary<string, string>>("api/settings")
                           ?? new();
            if (settings.TryGetValue("plaid_environment", out var e))
                _plaidEnvironment = e;
            if (settings.TryGetValue("output_year", out var y) && int.TryParse(y, out var yi))
                _outputYear = yi;

            var versionResp = await Http.GetFromJsonAsync<Dictionary<string, string>>("api/version");
            if (versionResp?.TryGetValue("version", out var v) == true)
                _version = v;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
