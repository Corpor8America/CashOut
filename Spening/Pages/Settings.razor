@page "/settings"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Settings</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <MudPaper Elevation="1" Class="pa-6" MaxWidth="600px">
        <MudSimpleTable Elevation="0">
            <tbody>
                <tr>
                    <td><strong>Plaid Environment</strong></td>
                    <td>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudChip T="string" Color="@(_plaidEnvironment == "production" ? Color.Error : Color.Info)" Size="Size.Small" Variant="Variant.Filled">
                                @_plaidEnvironment.ToUpper()
                            </MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                (set via <code>PLAID_ENV</code> env var)
                            </MudText>
                        </MudStack>
                    </td>
                </tr>
                <tr>
                    <td><strong>Active Year</strong></td>
                    <td>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText>@_outputYear</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                (from most recent transaction)
                            </MudText>
                        </MudStack>
                    </td>
                </tr>
                <tr>
                    <td><strong>Version</strong></td>
                    <td><MudText Typo="Typo.body2" Style="font-family:monospace">@_version</MudText></td>
                </tr>
            </tbody>
        </MudSimpleTable>

        @if (_plaidEnvironment == "production")
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-6" Icon="@Icons.Material.Filled.Warning">
                Production mode — using real financial data.
            </MudAlert>
        }

        @if (_plaidEnvironment == "sandbox")
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-6" Icon="@Icons.Material.Filled.Info">
                Sandbox mode — safe for testing with Plaid test credentials.
            </MudAlert>
        }
    </MudPaper>
}

@code {
    private string _plaidEnvironment = "sandbox";
    private int _outputYear = DateTime.Now.Year;
    private string _version = "—";
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await Http.GetFromJsonAsync<Dictionary<string, string>>("api/settings")
                           ?? new();
            if (settings.TryGetValue("plaid_environment", out var e))
                _plaidEnvironment = e;
            if (settings.TryGetValue("output_year", out var y) && int.TryParse(y, out var yi))
                _outputYear = yi;

            var versionResp = await Http.GetFromJsonAsync<Dictionary<string, string>>("api/version");
            if (versionResp?.TryGetValue("version", out var v) == true)
                _version = v;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
