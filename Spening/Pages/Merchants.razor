@page "/merchants"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Merchants</MudText>
<MudText Typo="Typo.body1" Class="text-muted mb-4">
    Define aliases and match patterns to normalize merchant names automatically during import.
    Alias categories override all other sources. Merchants without a matching alias are placed
    in <strong>Unassigned</strong> for manual review.
</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}
@if (_message != null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="my-4">@_message</MudAlert>
}

<MudTabs Elevation="1" Rounded="true" Color="Color.Primary" @bind-ActivePanelIndex="_activeTabIndex">
    <MudTabPanel Text="Aliases & Patterns" OnClick="() => SetTab(0)">
        <MudPaper Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" Class="mb-4">Add New Alias</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                <MudTextField @bind-Value="_newAliasName" Label="Alias name (e.g. Amazon)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:250px" />
                <MudTextField @bind-Value="_newAliasCategory" Label="Category (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:300px" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddAlias" Disabled="@_saving" StartIcon="@Icons.Material.Filled.Add">
                    @(_saving ? "Adding…" : "Add Alias")
                </MudButton>
            </MudStack>
        </MudPaper>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
        }
        else if (_aliases.Count == 0)
        {
            <MudText Color="Color.Secondary">No aliases yet. Add one above to start normalizing merchant names.</MudText>
        }
        else
        {
            @foreach (var alias in _aliases)
            {
                <MudCard Elevation="1" Class="mb-4">
                    <MudCardHeader Class="pb-2" Style="background-color: var(--mud-palette-background-grey)">
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                @if (_editingAlias == alias.Id)
                                {
                                    <MudTextField @bind-Value="_editAliasName" Label="Alias name" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:180px" />
                                    <MudTextField @bind-Value="_editAliasCategory" Label="Category" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:220px" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="() => SaveAlias(alias.Id)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="CancelAliasEdit" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.h6">@alias.AliasName</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                                    <MudChip T="string" Color="@(string.IsNullOrEmpty(alias.Category) ? Color.Default : Color.Primary)" Size="Size.Small" Variant="Variant.Text">
                                        @(string.IsNullOrEmpty(alias.Category) ? "Unassigned" : alias.Category)
                                    </MudChip>
                                    <MudSpacer />
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => StartAliasEdit(alias.Id, alias.AliasName, alias.Category)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteAlias(alias.Id)" />
                                }
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.overline" Class="mb-2">Match Patterns</MudText>
                        
                        @if (alias.Patterns.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                No patterns yet — this alias won't match any transactions automatically.
                            </MudText>
                        }
                        else
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-4">
                                @foreach (var p in alias.Patterns)
                                {
                                    <MudChip T="string" Color="Color.Tertiary" Variant="Variant.Filled" OnClose="() => DeletePattern(p.Id)" Size="Size.Small">
                                        <MudText Typo="Typo.caption" Class="mr-1" Style="opacity:0.7">@p.MatchType</MudText>
                                        <code>@p.Pattern</code>
                                    </MudChip>
                                }
                            </MudStack>
                        }

                        @if (_addingPatternForAlias == alias.Id)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                                <MudSelect T="string" @bind-Value="_newPatternType" Label="Type" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width:130px">
                                    <MudSelectItem Value="@("Contains")">Contains</MudSelectItem>
                                    <MudSelectItem Value="@("StartsWith")">Starts With</MudSelectItem>
                                    <MudSelectItem Value="@("Regex")">Regex</MudSelectItem>
                                </MudSelect>
                                <MudTextField @bind-Value="_newPatternText" Label="@PatternPlaceholder(_newPatternType)" 
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:300px" 
                                              OnKeyDown="@(e => OnPatternKey(e, alias.Id))" HelperText="@PatternHint(_newPatternType)" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => AddPattern(alias.Id)">Add</MudButton>
                                <MudButton Variant="Variant.Outlined" OnClick="CancelAddPattern">Cancel</MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="() => StartAddPattern(alias.Id)">Add Pattern</MudButton>
                        }
                    </MudCardContent>
                </MudCard>
            }
        }
    </MudTabPanel>

    <MudTabPanel Text="@($"Unmapped ({_unmapped.Count})")" OnClick="() => SetTab(1)">
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_unmapped.Count unmapped merchant name(s) — map each to an alias, or it will remain in Unassigned.
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Refresh" 
                           OnClick="RetroactiveMap" Disabled="@_retroMapping">
                    @(_retroMapping ? "Running…" : "Re-run Pattern Matching")
                </MudButton>
            </MudStack>

            <MudTextField @bind-Value="_rawFilter" Label="Filter by name…" Variant="Variant.Outlined" Margin="Margin.Dense" 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" />

            @{
                var filtered = string.IsNullOrWhiteSpace(_rawFilter)
                    ? _unmapped
                    : _unmapped
                        .Where(b => b.RawName.Contains(_rawFilter, StringComparison.OrdinalIgnoreCase)
                                 || b.RawNameNormalized.Contains(_rawFilter, StringComparison.OrdinalIgnoreCase))
                        .ToList();
            }

            <MudTable Items="@filtered" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Original Name</MudTh>
                    <MudTh>Normalized</MudTh>
                    <MudTh>Source Category</MudTh>
                    <MudTh>Map to Alias</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Original Name">@context.RawName</MudTd>
                    <MudTd DataLabel="Normalized">
                        <code style="font-size:0.85em">@context.RawNameNormalized</code>
                    </MudTd>
                    <MudTd DataLabel="Source Category" Class="text-muted">
                        @(string.IsNullOrEmpty(context.CategoryRaw) ? "—" : context.CategoryRaw)
                    </MudTd>
                    <MudTd DataLabel="Map to Alias">
                        @if (_mappingRawId == context.Id)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudSelect T="int" @bind-Value="_mappingTargetAliasId" Label="Select Alias" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width:160px">
                                    <MudSelectItem Value="0">— select —</MudSelectItem>
                                    @foreach (var a in _aliases)
                                    {
                                        <MudSelectItem Value="@a.Id">@a.AliasName</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="() => SaveMapping(context.Id)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="CancelMapping" />
                            </MudStack>
                        }
                        else
                        {
                            @if (_aliases.Count > 0)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="() => StartMapping(context.Id)">Map to alias</MudButton>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">No aliases yet</MudText>
                            }
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Pattern Tester" OnClick="() => SetTab(2)">
        <MudPaper Class="pa-6" MaxWidth="620px" Elevation="0">
            <MudText Typo="Typo.body1" Class="mb-4">
                Enter a raw merchant string to see how the normalization pipeline resolves it.
            </MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
                <MudTextField @bind-Value="_testInput" Label="Raw merchant string" Placeholder="e.g. AMZN MKTP US 123456789 (Amazon.com)" 
                              Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" OnKeyDown="OnTestKey" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunTest" Disabled="@_testing">
                    @(_testing ? "Testing…" : "Test")
                </MudButton>
            </MudStack>

            @if (_testResult != null)
            {
                <MudSimpleTable Style="width:100%" Elevation="1">
                    <tbody>
                        <tr>
                            <td><strong>Raw Input</strong></td>
                            <td><code>@_testResult.RawInput</code></td>
                        </tr>
                        <tr>
                            <td><strong>Normalized</strong></td>
                            <td><code style="color: var(--mud-palette-tertiary)">@_testResult.Normalized</code></td>
                        </tr>
                        <tr>
                            <td><strong>Matched Alias</strong></td>
                            <td>
                                @if (_testResult.MatchedAliasId != null)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                        <MudText Color="Color.Success" Style="font-weight:bold">@_testResult.MatchedAliasName</MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary" Typo="Typo.body2">No match — will create RawBusiness</MudText>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Effective Category</strong></td>
                            <td>
                                <MudChip T="string" Color="@(_testResult.EffectiveCategory == "Unassigned" ? Color.Default : Color.Primary)" Size="Size.Small" Variant="Variant.Text" Style="font-weight:bold">
                                    @_testResult.EffectiveCategory
                                </MudChip>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudTabPanel>
</MudTabs>

@code {
    private int _activeTabIndex = 0;

    private List<AliasDto> _aliases = new();
    private List<RawBizDto> _unmapped = new();
    private bool _loading = true;
    private bool _saving;
    private bool _retroMapping;
    private bool _testing;
    private string? _error, _message;
    private string _rawFilter = "";

    // Add alias form
    private string _newAliasName = "";
    private string _newAliasCategory = "";

    // Alias category edit
    private int _editingAlias;
    private string _editAliasName = "";
    private string _editAliasCategory = "";

    // Pattern form
    private int _addingPatternForAlias;
    private string _newPatternText = "";
    private string _newPatternType = "Contains";

    // Mapping form
    private int _mappingRawId;
    private int _mappingTargetAliasId;

    // Pattern tester
    private string _testInput = "";
    private PatternTestResultDto? _testResult;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task SetTab(int index)
    {
        _activeTabIndex = index;
        _message = null;
        _error = null;
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true; _error = null;
        try
        {
            var aliasTask = Http.GetFromJsonAsync<List<AliasDto>>("api/normalization/aliases");
            var unmappedTask = Http.GetFromJsonAsync<List<RawBizDto>>("api/normalization/businesses?unmappedOnly=true");
            await Task.WhenAll(aliasTask, unmappedTask);
            _aliases = await aliasTask ?? new();
            _unmapped = await unmappedTask ?? new();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    // ── Aliases ───────────────────────────────────────────────────────────

    private async Task AddAlias()
    {
        if (string.IsNullOrWhiteSpace(_newAliasName)) return;
        _saving = true; _message = null; _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/normalization/aliases",
                new { AliasName = _newAliasName, Category = _newAliasCategory });
            resp.EnsureSuccessStatusCode();
            var result = await resp.Content.ReadFromJsonAsync<CreateAliasResult>();
            _newAliasName = "";
            _newAliasCategory = "";
            _message = result?.Matched > 0
                ? $"Alias added — {result.Matched} transaction(s) matched automatically."
                : "Alias added.";
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private void StartAliasEdit(int id, string currentName, string currentCategory)
    {
        _editingAlias = id;
        _editAliasName = currentName;
        _editAliasCategory = currentCategory;
        _addingPatternForAlias = 0;
    }

    private async Task SaveAlias(int id)
    {
        _error = null;
        try
        {
            var nameResp = await Http.PatchAsJsonAsync(
                $"api/normalization/aliases/{id}/name",
                new { AliasName = _editAliasName });
            nameResp.EnsureSuccessStatusCode();

            var categoryResp = await Http.PatchAsJsonAsync(
                $"api/normalization/aliases/{id}/category",
                new { Category = _editAliasCategory });
            categoryResp.EnsureSuccessStatusCode();
            _message = "Alias updated.";
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { CancelAliasEdit(); }
    }

    private async Task OnAliasKey(KeyboardEventArgs e, int id)
    {
        if (e.Key == "Enter") await SaveAlias(id);
        else if (e.Key == "Escape") CancelAliasEdit();
    }

    private void CancelAliasEdit() { _editingAlias = 0; _editAliasName = ""; _editAliasCategory = ""; }

    private async Task DeleteAlias(int id)
    {
        _error = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/normalization/aliases/{id}");
            resp.EnsureSuccessStatusCode();
            var result = await resp.Content.ReadFromJsonAsync<Dictionary<string, int>>();
            var reprocessed = result?["reprocessed"] ?? 0;
            _message = $"Alias deleted. Reprocessed {reprocessed} transaction(s).";
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    // ── Patterns ──────────────────────────────────────────────────────────

    private void StartAddPattern(int aliasId)
    {
        _addingPatternForAlias = aliasId;
        _newPatternText = "";
        _newPatternType = "Contains";
        _editingAlias = 0;
    }

    private void CancelAddPattern() { _addingPatternForAlias = 0; _newPatternText = ""; }

    private async Task AddPattern(int aliasId)
    {
        if (string.IsNullOrWhiteSpace(_newPatternText)) return;
        _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync(
                $"api/normalization/aliases/{aliasId}/patterns",
                new { Pattern = _newPatternText, MatchType = _newPatternType });

            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                _error = err?["error"] ?? "Failed to add pattern.";
                return;
            }
            _message = "Pattern added.";
            CancelAddPattern();
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task OnPatternKey(KeyboardEventArgs e, int aliasId)
    {
        if (e.Key == "Enter") await AddPattern(aliasId);
        else if (e.Key == "Escape") CancelAddPattern();
    }

    private async Task DeletePattern(int patternId)
    {
        _error = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/normalization/patterns/{patternId}");
            resp.EnsureSuccessStatusCode();
            _message = "Pattern removed.";
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string PatternPlaceholder(string type) => type switch
    {
        "StartsWith" => "e.g. AMAZON",
        "Regex" => "e.g. AMAZON.*MKTP",
        _ => "e.g. AMAZON"
    };

    private static string PatternHint(string type) => type switch
    {
        "Contains" => "Matches if the normalized merchant name contains this text (case-insensitive).",
        "StartsWith" => "Matches if the normalized merchant name starts with this text.",
        "Regex" => "Advanced: regular expression matched against the normalized name.",
        _ => ""
    };

    // ── Unmapped / Retroactive ────────────────────────────────────────────

    private async Task RetroactiveMap()
    {
        _retroMapping = true; _message = null; _error = null;
        try
        {
            var resp = await Http.PostAsync("api/normalization/retroactive-map", null);
            resp.EnsureSuccessStatusCode();
            var result = await resp.Content.ReadFromJsonAsync<Dictionary<string, int>>();
            var count = result?["matched"] ?? result?["mapped"] ?? 0;
            _message = count > 0
                ? $"{count} transaction(s) newly matched."
                : "No new matches found.";
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _retroMapping = false; }
    }

    private void StartMapping(int rawBusinessId)
    {
        _mappingRawId = rawBusinessId;
        _mappingTargetAliasId = 0;
    }

    private async Task SaveMapping(int rawBusinessId)
    {
        if (_mappingTargetAliasId == 0) return;
        _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/normalization/mappings",
                new { RawBusinessId = rawBusinessId, AliasId = _mappingTargetAliasId });
            resp.EnsureSuccessStatusCode();
            _message = "Merchant mapped to alias.";
            CancelMapping();
            await LoadAll();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void CancelMapping() { _mappingRawId = 0; _mappingTargetAliasId = 0; }

    // ── Pattern tester ────────────────────────────────────────────────────

    private async Task RunTest()
    {
        if (string.IsNullOrWhiteSpace(_testInput)) return;
        _testing = true; _testResult = null; _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/normalization/aliases/test",
                new { RawInput = _testInput });
            resp.EnsureSuccessStatusCode();
            _testResult = await resp.Content.ReadFromJsonAsync<PatternTestResultDto>();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _testing = false; }
    }

    private async Task OnTestKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunTest();
    }

    // ── DTOs ──────────────────────────────────────────────────────────────

    private record PatternDto(int Id, int AliasId, string Pattern, string MatchType);
    private record AliasDto(int Id, string AliasName, string Category, List<PatternDto> Patterns);
    private record RawBizDto(int Id, string RawName, string RawNameNormalized,
        string CategoryRaw, bool IsMapped);
    private record PatternTestResultDto(string RawInput, string Normalized,
        int? MatchedAliasId, string? MatchedAliasName, string EffectiveCategory);
    private record CreateAliasResult(int Id, string AliasName, string Category, int Matched);
}
