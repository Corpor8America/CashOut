@page "/accounts"
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JS
@inject ILogger<Accounts> Logger
@implements IDisposable

<MudText Typo="Typo.h4" GutterBottom="true">Linked Accounts</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else if (_accounts.Count == 0)
{
    <MudText Color="Color.Secondary" Class="mb-4">No accounts linked yet.</MudText>
}
else
{
    <MudTable Items="@_accounts" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1" Dense="true" Class="mb-4">
        <HeaderContent>
            <MudTh>Institution</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Account #</MudTh>
            <MudTh>Type</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Institution">@context.Institution</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Account #">••••@context.Mask</MudTd>
            <MudTd DataLabel="Type">@context.Subtype</MudTd>
            <MudTd>
                @if (_confirmRemoveId == context.Id)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">Sure?</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmRemove(context.Id)">Yes, remove</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="CancelRemove">Cancel</MudButton>
                    </MudStack>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="() => RequestRemove(context.Id)">Remove</MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartLinkFlow" 
           Disabled="@(!_isRendered || _linking)" StartIcon="@(_linking ? null : Icons.Material.Filled.Add)">
    @if (!_isRendered)
    {
        <span>Loading…</span>
    }
    else if (_linking)
    {
        <span>Connecting...</span>
    }
    else
    {
        <span>Add Account</span>
    }
</MudButton>

@if (_newAccounts.Count > 0)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mt-4">Added @_newAccounts.Count account(s) successfully.</MudAlert>
}

@code {
    private List<AccountDto> _accounts = new();
    private List<object> _newAccounts = new();
    private bool _loading = true;
    private bool _linking = false;
    private bool _isRendered = false;
    private string? _error;
    private Guid? _confirmRemoveId;
    private DotNetObjectReference<Accounts>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Accounts: OnInitializedAsync");
        await LoadAccounts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Logger.LogInformation("Accounts: first real browser render complete");
            _isRendered = true;
            StateHasChanged();
            try
            {
                await JS.InvokeVoidAsync("console.log", "[Blazor] Accounts page JS interop OK");
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Accounts: JS interop failed on first render");
            }
        }
    }

    private async Task LoadAccounts()
    {
        _loading = true;
        _error = null;
        try
        {
            Logger.LogInformation("Accounts: fetching api/accounts");
            _accounts = await Http.GetFromJsonAsync<List<AccountDto>>("api/accounts") ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Accounts: LoadAccounts failed");
            _error = $"Failed to load accounts: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private async Task StartLinkFlow()
    {
        Logger.LogInformation("Accounts: StartLinkFlow clicked, _isRendered={IsRendered}", _isRendered);

        if (!_isRendered)
        {
            _error = "Page not fully loaded yet. Please wait a moment.";
            StateHasChanged();
            return;
        }

        _linking = true;
        _error = null;
        _newAccounts.Clear();
        StateHasChanged();

        try
        {
            Logger.LogInformation("Accounts: requesting link token");
            var resp = await Http.PostAsync("api/plaid/link-token", null);

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                throw new Exception($"HTTP {(int)resp.StatusCode}: {body}");
            }

            var json = await resp.Content.ReadFromJsonAsync<Dictionary<string, string>>();
            var linkToken = json?["link_token"] ?? throw new Exception("link_token missing from response");

            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("speningPlaid.open", linkToken, _dotNetRef);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Accounts: StartLinkFlow failed");
            _error = $"Could not start Plaid Link: {ex.Message}";
            _linking = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnPlaidSuccess(string publicToken)
    {
        Logger.LogInformation("Accounts: OnPlaidSuccess");
        try
        {
            var resp = await Http.PostAsJsonAsync("api/plaid/exchange",
                new { PublicToken = publicToken });
            resp.EnsureSuccessStatusCode();
            _newAccounts = await resp.Content.ReadFromJsonAsync<List<object>>() ?? new();
            await LoadAccounts();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Accounts: OnPlaidSuccess exchange failed");
            _error = $"Account linking failed: {ex.Message}";
        }
        finally
        {
            _linking = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnPlaidExit()
    {
        Logger.LogInformation("Accounts: OnPlaidExit");
        _linking = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnPlaidError(string message)
    {
        Logger.LogError("Accounts: OnPlaidError: {Message}", message);
        _error = message;
        _linking = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void RequestRemove(Guid id) => _confirmRemoveId = id;
    private void CancelRemove() => _confirmRemoveId = null;

    private async Task ConfirmRemove(Guid id)
    {
        _error = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/accounts/{id}");
            resp.EnsureSuccessStatusCode();
            await LoadAccounts();
        }
        catch (Exception ex)
        {
            _error = $"Remove failed: {ex.Message}";
        }
        finally { _confirmRemoveId = null; }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private record AccountDto(Guid Id, string Name, string Mask,
        string Subtype, string Institution);
}
