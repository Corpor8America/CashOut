@page "/manual-accounts"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Manual Accounts</MudText>
<MudText Typo="Typo.body1" Class="text-muted mb-4">
    CSV-only accounts — no Plaid connection. Import transactions via CSV upload.
</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}
@if (_message != null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="my-4">@_message</MudAlert>
}

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else if (_accounts.Count == 0)
{
    <MudText Color="Color.Secondary" Class="mb-4">No manual accounts yet. Add one below.</MudText>
}
else
{
    <MudTable Items="@_accounts" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1" Dense="true" Class="mb-6">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Created</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Description" Class="text-muted">@(string.IsNullOrEmpty(context.Description) ? "—" : context.Description)</MudTd>
            <MudTd DataLabel="Created" Class="text-muted">@context.CreatedAt.ToString("MMM d, yyyy")</MudTd>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" 
                               Href="@($"/csv-import/{context.Id}")" StartIcon="@Icons.Material.Filled.Upload">
                        Import CSV
                    </MudButton>
                    
                    @if (_confirmDeleteId == context.Id)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Error">Delete everything?</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => ConfirmDelete(context.Id)">Yes</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="CancelDelete">Cancel</MudButton>
                        </MudStack>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                    OnClick="() => RequestDelete(context.Id)">Delete</MudButton>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudPaper Class="pa-4 mt-6">
    <MudText Typo="Typo.h6" Class="mb-4">Add Manual Account</MudText>
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
        <MudTextField @bind-Value="_newName" Label="Account name" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:200px" />
        <MudTextField @bind-Value="_newDescription" Label="Description (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:300px" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddAccount" Disabled="@_adding" 
                   StartIcon="@Icons.Material.Filled.Add">
            @(_adding ? "Adding..." : "Add Account")
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private List<AccountDto> _accounts = new();
    private bool _loading = true;
    private bool _adding;
    private string _newName = "";
    private string _newDescription = "";
    private Guid? _confirmDeleteId;
    private string? _error, _message;

    protected override async Task OnInitializedAsync() => await LoadAccounts();

    private async Task LoadAccounts()
    {
        _loading = true; _error = null;
        try
        {
            _accounts = await Http.GetFromJsonAsync<List<AccountDto>>("api/manual-accounts") ?? new();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task AddAccount()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        _adding = true; _message = null; _error = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/manual-accounts",
                new { Name = _newName, Description = _newDescription });
            resp.EnsureSuccessStatusCode();
            _newName = "";
            _newDescription = "";
            _message = "Account added.";
            await LoadAccounts();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _adding = false; }
    }

    private void RequestDelete(Guid id) => _confirmDeleteId = id;
    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDelete(Guid id)
    {
        _error = null; _message = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/manual-accounts/{id}");
            resp.EnsureSuccessStatusCode();
            _message = "Account and its transactions deleted.";
            await LoadAccounts();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _confirmDeleteId = null; }
    }

    private record AccountDto(Guid Id, string Name, string Description, DateTime CreatedAt);
}
