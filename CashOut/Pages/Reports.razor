@page "/reports"
@inject HttpClient Http

<ReportShell Title="Executive Summary"
             Year="_year"
             AvailableYears="_availableYears"
             OnYearChanged="OnYearChanged"
             Month="_month"
             OnMonthChanged="OnMonthChanged"
             ShowMonthPicker="true"
             Loading="_loading"
             Error="@_error"
             ExportHref="@ExportUrl">
    @if (_summary is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No summary data found for @_year.
        </MudAlert>
    }
    else
    {
        <div class="dashboard-section">
            <div class="section-title">@(_summary.Month == 0 ? "Year-to-Date Overview" : "Monthly Overview") — @_summary.MonthLabel</div>
            <div class="summary-grid">
                <div class="metric-panel">
                    <div class="metric-label">Total Spending</div>
                    <div class="metric-value">@_summary.MonthlyOverview.TotalSpending.ToString("C")</div>
                    <div class="metric-sub @ChangeClass(_summary.MonthlyOverview.SpendingChangeAmount)">
                        @_vsLabel: @(_summary.MonthlyOverview.SpendingChangeAmount >= 0 ? "+" : "")@_summary.MonthlyOverview.SpendingChangeAmount.ToString("C")
                        (@(_summary.MonthlyOverview.SpendingChangePercent >= 0 ? "+" : "")@_summary.MonthlyOverview.SpendingChangePercent.ToString("F1")%)
                    </div>
                </div>
                <div class="metric-panel">
                    <div class="metric-label">Total Income</div>
                    <div class="metric-value income-value">@_summary.MonthlyOverview.TotalIncome.ToString("C")</div>
                    <div class="metric-sub @PosChangeClass(_summary.MonthlyOverview.IncomeChangeAmount)">
                        @_vsLabel: @(_summary.MonthlyOverview.IncomeChangeAmount >= 0 ? "+" : "")@_summary.MonthlyOverview.IncomeChangeAmount.ToString("C")
                        (@(_summary.MonthlyOverview.IncomeChangePercent >= 0 ? "+" : "")@_summary.MonthlyOverview.IncomeChangePercent.ToString("F1")%)
                    </div>
                </div>
                <div class="metric-panel">
                    <div class="metric-label">Net Cash Flow</div>
                    <div class="metric-value @NetClass(_summary.MonthlyOverview.NetCashFlow)">@_summary.MonthlyOverview.NetCashFlow.ToString("C")</div>
                    <div class="metric-sub @NetClass(_summary.MonthlyOverview.NetCashFlowChangeAmount)">
                        @_vsLabel: @(_summary.MonthlyOverview.NetCashFlowChangeAmount >= 0 ? "+" : "")@_summary.MonthlyOverview.NetCashFlowChangeAmount.ToString("C")
                        (@(_summary.MonthlyOverview.NetCashFlowChangePercent >= 0 ? "+" : "")@_summary.MonthlyOverview.NetCashFlowChangePercent.ToString("F1")%)
                    </div>
                </div>
                <div class="metric-panel">
                    <div class="metric-label">Transactions</div>
                    <div class="metric-value">@_summary.MonthlyOverview.TransactionCount.ToString("N0")</div>
                    <div class="metric-sub">@_summary.MonthlyOverview.IncomeTransactionCount income / @_summary.MonthlyOverview.ExpenseTransactionCount expenses</div>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="section-title">Top Spending Categories</div>
            @if (_summary.TopCategories.Count == 0)
            {
                <MudText Typo="Typo.body2">No category spending for @(_summary.Month == 0 ? "this year" : "this month").</MudText>
            }
            else
            {
                <MudTable Items="@_summary.TopCategories"
                          Dense="true"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0">
                    <ColGroup>
                        <col style="width: 28%" />
                        <col style="width: 18%" />
                        <col style="width: 14%" />
                        <col style="width: 14%" />
                        <col style="width: 26%" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Category</MudTh>
                        <MudTh Class="right-align">Total</MudTh>
                        <MudTh Class="right-align">Percent</MudTh>
                        <MudTh Class="right-align">Transactions</MudTh>
                        <MudTh Class="right-align">Change</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="cat">
                        <MudTd DataLabel="Category">@cat.Category</MudTd>
                        <MudTd DataLabel="Total" Class="right-align">@cat.Total.ToString("C")</MudTd>
                        <MudTd DataLabel="Percent" Class="right-align">@cat.PctOfSpend.ToString("F1")%</MudTd>
                        <MudTd DataLabel="Transactions" Class="right-align">@cat.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="Change" Class="@ChangeAlignClass(cat.ChangeAmount)">
                            @(cat.ChangeAmount >= 0 ? "+" : "")@cat.ChangeAmount.ToString("C")
                            <span class="change-pct">(@(cat.ChangePercent >= 0 ? "+" : "")@cat.ChangePercent.ToString("F1")%)</span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>

        <div class="dashboard-section">
            <div class="section-title">Top Spending Merchants</div>
            @if (_summary.TopMerchants.Count == 0)
            {
                <MudText Typo="Typo.body2">No merchant spending for @(_summary.Month == 0 ? "this year" : "this month").</MudText>
            }
            else
            {
                <MudTable Items="@_summary.TopMerchants"
                          Dense="true"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0">
                    <ColGroup>
                        <col style="width: 22%" />
                        <col style="width: 14%" />
                        <col style="width: 16%" />
                        <col style="width: 12%" />
                        <col style="width: 10%" />
                        <col style="width: 26%" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Merchant</MudTh>
                        <MudTh>Category</MudTh>
                        <MudTh Class="right-align">Total</MudTh>
                        <MudTh Class="right-align">Percent</MudTh>
                        <MudTh Class="right-align">Txns</MudTh>
                        <MudTh Class="right-align">Change</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="merch">
                        <MudTd DataLabel="Merchant">
                            <div>@merch.Name</div>
                            @if (!merch.IsMapped && !string.IsNullOrWhiteSpace(merch.NormalizedName) && merch.NormalizedName != merch.Name)
                            {
                                <div class="muted-subtext">@merch.NormalizedName</div>
                            }
                        </MudTd>
                        <MudTd DataLabel="Category">@merch.PrimaryCategory</MudTd>
                        <MudTd DataLabel="Total" Class="right-align">@merch.Total.ToString("C")</MudTd>
                        <MudTd DataLabel="Percent" Class="right-align">@merch.PctOfSpend.ToString("F1")%</MudTd>
                        <MudTd DataLabel="Txns" Class="right-align">@merch.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="Change" Class="@ChangeAlignClass(merch.ChangeAmount)">
                            @(merch.ChangeAmount >= 0 ? "+" : "")@merch.ChangeAmount.ToString("C")
                            <span class="change-pct">(@(merch.ChangePercent >= 0 ? "+" : "")@merch.ChangePercent.ToString("F1")%)</span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>

        <div class="dashboard-section">
            <div class="section-title">Recurring Charges</div>
            @if (_summary.RecurringCharges.Count == 0)
            {
                <MudText Typo="Typo.body2">No recurring charge candidates found.</MudText>
            }
            else
            {
                <MudTable Items="@_summary.RecurringCharges"
                          Dense="true"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0">
                    <ColGroup>
                        <col style="width: 20%" />
                        <col style="width: 12%" />
                        <col style="width: 14%" />
                        <col style="width: 14%" />
                        <col style="width: 10%" />
                        <col style="width: 14%" />
                        <col style="width: 10%" />
                        <col style="width: 6%" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Merchant</MudTh>
                        <MudTh>Category</MudTh>
                        <MudTh Class="right-align">Latest Amount</MudTh>
                        <MudTh Class="right-align">Avg Amount</MudTh>
                        <MudTh Class="right-align">Occurrences</MudTh>
                        <MudTh Class="right-align">Latest Date</MudTh>
                        <MudTh>Cadence</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="rc">
                        <MudTd DataLabel="Merchant">@rc.Name</MudTd>
                        <MudTd DataLabel="Category">@rc.Category</MudTd>
                        <MudTd DataLabel="Latest Amount" Class="right-align">@rc.LatestAmount.ToString("C")</MudTd>
                        <MudTd DataLabel="Avg Amount" Class="right-align">@rc.AverageAmount.ToString("C")</MudTd>
                        <MudTd DataLabel="Occurrences" Class="right-align">@rc.OccurrenceCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="Latest Date" Class="right-align">@rc.LatestDate.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd DataLabel="Cadence">@rc.Cadence</MudTd>
                        <MudTd>
                            @if (rc.IsAmountChanged)
                            {
                                <span class="warning-chip">Changed</span>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>

        <div class="dashboard-section">
            <div class="section-title">Alerts</div>
            @if (_summary.Alerts.Items.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                    No report alerts for this year.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@_summary.Alerts.Items"
                          Dense="true"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>Severity</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Detail</MudTh>
                        <MudTh Class="right-align">Count</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="alert">
                        <MudTd DataLabel="Severity">
                            <span class="@AlertSeverityClass(alert.Severity)">@alert.Severity</span>
                        </MudTd>
                        <MudTd DataLabel="Title">@alert.Title</MudTd>
                        <MudTd DataLabel="Detail">@alert.Detail</MudTd>
                        <MudTd DataLabel="Count" Class="right-align">@alert.Count.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>

        <div class="dashboard-section">
            <div class="section-title">Account Summary</div>
            @if (_summary.Accounts.Count == 0)
            {
                <MudText Typo="Typo.body2">No account activity for this year.</MudText>
            }
            else
            {
                <MudTable Items="@_summary.Accounts"
                          Dense="true"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0">
                    <ColGroup>
                        <col style="width: 20%" />
                        <col style="width: 14%" />
                        <col style="width: 18%" />
                        <col style="width: 18%" />
                        <col style="width: 18%" />
                        <col style="width: 12%" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Account</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh Class="right-align">Income</MudTh>
                        <MudTh Class="right-align">Expenses</MudTh>
                        <MudTh Class="right-align">Net</MudTh>
                        <MudTh Class="right-align">Transactions</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="acct">
                        <MudTd DataLabel="Account">@acct.AccountName</MudTd>
                        <MudTd DataLabel="Type">@acct.AccountType</MudTd>
                        <MudTd DataLabel="Income" Class="right-align income-value">@acct.Income.ToString("C")</MudTd>
                        <MudTd DataLabel="Expenses" Class="right-align expense-value">@acct.Expenses.ToString("C")</MudTd>
                        <MudTd DataLabel="Net" Class="@NetAlignClass(acct.NetCashFlow)">@acct.NetCashFlow.ToString("C")</MudTd>
                        <MudTd DataLabel="Transactions" Class="right-align">@acct.TransactionCount.ToString("N0")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>
    }
</ReportShell>

<style>
    .dashboard-section {
        margin-bottom: 24px;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 12px;
        padding-bottom: 4px;
        border-bottom: 1px solid var(--mud-palette-lines-inputs, #e0e0e0);
    }
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
    }
    .metric-panel {
        padding: 12px 16px;
        border: 1px solid var(--mud-palette-lines-inputs, #e0e0e0);
        border-radius: 8px;
    }
    .metric-label {
        font-size: 0.8rem;
        color: var(--mud-palette-text-secondary, #757575);
        margin-bottom: 4px;
    }
    .metric-value {
        font-size: 1.5rem;
        font-weight: 600;
    }
    .metric-sub {
        font-size: 0.85rem;
        margin-top: 2px;
    }
    .income-value { color: #1b5e20; }
    .expense-value { color: #b71c1c; }
    .net-positive { color: #1b5e20; }
    .net-negative { color: #b71c1c; }
    .positive-change { color: #1b5e20; }
    .negative-change { color: #b71c1c; }
    .neutral-change { color: var(--mud-palette-text-secondary, #757575); }
    .warning-chip {
        display: inline-block;
        padding: 0 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 500;
        background: #fff3e0;
        color: #e65100;
    }
    .alert-warning {
        display: inline-block;
        padding: 0 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 500;
        background: #fff3e0;
        color: #e65100;
    }
    .alert-info {
        display: inline-block;
        padding: 0 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 500;
        background: #e3f2fd;
        color: #0d47a1;
    }
    .right-align { text-align: right; }
    .change-pct {
        display: inline-block;
        margin-left: 4px;
    }
    .muted-subtext {
        font-size: 0.8rem;
        color: var(--mud-palette-text-secondary, #757575);
    }
    ::deep .mud-table-root .right-align {
        text-align: right;
    }
</style>

@code {
    private int _year = DateTime.Now.Year;
    private int? _month;
    private List<int> _availableYears = new() { DateTime.Now.Year };
    private bool _loading;
    private string? _error;
    private ExecutiveSummaryResult? _summary;
    private string _vsLabel => _summary?.Month == 0 ? "vs prev year" : "vs prev month";

    protected override async Task OnInitializedAsync()
    {
        await LoadYears();
        await LoadSummary();
    }

    private async Task LoadYears()
    {
        try
        {
            _availableYears = await Http.GetFromJsonAsync<List<int>>("api/settings/years")
                              ?? _availableYears;
            if (_availableYears.Count > 0)
                _year = _availableYears[0];
        }
        catch
        {
            _availableYears = Enumerable.Range(DateTime.Now.Year - 6, 7)
                .OrderByDescending(y => y)
                .ToList();
        }
    }

    private async Task OnYearChanged(int year)
    {
        _year = year;
        _month = null;
        await LoadSummary();
    }

    private async Task OnMonthChanged(int? month)
    {
        _month = month;
        await LoadSummary();
    }

    private string ExportUrl =>
        _month.HasValue
            ? $"api/reports/summary?year={_year}&month={_month}&format=csv"
            : $"api/reports/summary?year={_year}&format=csv";

    private async Task LoadSummary()
    {
        _loading = true;
        _error = null;
        try
        {
            var url = _month.HasValue
                ? $"api/reports/summary?year={_year}&month={_month}"
                : $"api/reports/summary?year={_year}";
            _summary = await Http.GetFromJsonAsync<ExecutiveSummaryResult>(url);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private string NetClass(decimal value) => value switch
    {
        > 0 => "net-positive",
        < 0 => "net-negative",
        _ => "neutral-change"
    };

    private string NetAlignClass(decimal value) => $"right-align {NetClass(value)}";

    private string ChangeAlignClass(decimal value) => $"right-align {ChangeClass(value)}";

    private string ChangeClass(decimal value) => value switch
    {
        > 0 => "negative-change",
        < 0 => "positive-change",
        _ => "neutral-change"
    };

    private string PosChangeClass(decimal value) => value switch
    {
        > 0 => "positive-change",
        < 0 => "negative-change",
        _ => "neutral-change"
    };

    private string AlertSeverityClass(string severity) =>
        severity == "Warning" ? "alert-warning" : "alert-info";

    private record ExecutiveSummaryResult(
        int Year,
        int Month,
        string MonthKey,
        string MonthLabel,
        ExecutiveMonthlyOverview MonthlyOverview,
        List<ExecutiveTopCategoryRow> TopCategories,
        List<ExecutiveTopMerchantRow> TopMerchants,
        List<ExecutiveRecurringChargeRow> RecurringCharges,
        ExecutiveAlertSummary Alerts,
        List<ExecutiveAccountSummaryRow> Accounts);

    private record ExecutiveMonthlyOverview(
        decimal TotalSpending,
        decimal PreviousMonthSpending,
        decimal SpendingChangeAmount,
        decimal SpendingChangePercent,
        decimal TotalIncome,
        decimal PreviousMonthIncome,
        decimal IncomeChangeAmount,
        decimal IncomeChangePercent,
        decimal NetCashFlow,
        decimal PreviousMonthNetCashFlow,
        decimal NetCashFlowChangeAmount,
        decimal NetCashFlowChangePercent,
        int IncomeTransactionCount,
        int ExpenseTransactionCount,
        int TransactionCount);

    private record ExecutiveTopCategoryRow(
        string Category,
        decimal Total,
        decimal PctOfSpend,
        int Count,
        decimal PreviousMonthTotal,
        decimal ChangeAmount,
        decimal ChangePercent);

    private record ExecutiveTopMerchantRow(
        string MerchantKey,
        int? AliasId,
        string Name,
        string NormalizedName,
        bool IsMapped,
        string PrimaryCategory,
        decimal Total,
        decimal PctOfSpend,
        int Count,
        decimal PreviousMonthTotal,
        decimal ChangeAmount,
        decimal ChangePercent);

    private record ExecutiveRecurringChargeRow(
        string MerchantKey,
        string Name,
        string Category,
        decimal LatestAmount,
        decimal AverageAmount,
        decimal AmountChange,
        int OccurrenceCount,
        DateOnly LatestDate,
        string Cadence,
        bool IsAmountChanged);

    private record ExecutiveAlertSummary(
        int UnmatchedMerchantCount,
        int UncategorizedTransactionCount,
        int PossibleDuplicateCount,
        int RuleConflictCount,
        List<ExecutiveAlertRow> Items);

    private record ExecutiveAlertRow(
        string Severity,
        string Type,
        string Title,
        string Detail,
        int Count);

    private record ExecutiveAccountSummaryRow(
        string AccountId,
        string AccountName,
        string AccountType,
        decimal Income,
        decimal Expenses,
        decimal NetCashFlow,
        int TransactionCount);
}