@page "/reports"
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Reports</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}

<MudPaper Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
        <MudSelect T="int" Label="Year" Value="_year" ValueChanged="OnYearChanged" Dense="true" Margin="Margin.Dense" Style="width:100px">
            @foreach (var y in _availableYears)
            {
                <MudSelectItem Value="@y">@y</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Refresh" Disabled="@_loading">Refresh</MudButton>
    </MudStack>
</MudPaper>

<MudTabs Elevation="1" Rounded="true" Color="Color.Primary" @bind-ActivePanelIndex="_activeTabIndex">
    <MudTabPanel Text="Monthly" OnClick="() => SetTab(0)">
        <MudStack Spacing="4">
            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" 
                           Href="@($"api/reports/monthly?year={_year}&format=csv")" Target="_blank">
                    Export CSV
                </MudButton>
            </MudStack>
            <MudTable Items="@_monthly" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Month</MudTh>
                    <MudTh Style="text-align:right">Total</MudTh>
                    <MudTh Style="text-align:right">Transactions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Month">@context.Label</MudTd>
                    <MudTd DataLabel="Total" Style="text-align:right">@context.Total.ToString("C")</MudTd>
                    <MudTd DataLabel="Transactions" Style="text-align:right">@context.Count</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTFootRow Class="bold-footer">
                        <MudTd>Total</MudTd>
                        <MudTd Style="text-align:right">@_monthly.Sum(r => r.Total).ToString("C")</MudTd>
                        <MudTd Style="text-align:right">@_monthly.Sum(r => r.Count)</MudTd>
                    </MudTFootRow>
                </FooterContent>
            </MudTable>
        </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="By Category" OnClick="() => SetTab(1)">
        <MudStack Spacing="4">
            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" 
                           Href="@($"api/reports/category?year={_year}&format=csv")" Target="_blank">
                    Export CSV
                </MudButton>
            </MudStack>
            <MudTable Items="@_categories" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Category</MudTh>
                    <MudTh Style="text-align:right">Total</MudTh>
                    <MudTh Style="text-align:right">% of Spend</MudTh>
                    <MudTh Style="text-align:right">Transactions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Category">@context.Category</MudTd>
                    <MudTd DataLabel="Total" Style="text-align:right">@context.Total.ToString("C")</MudTd>
                    <MudTd DataLabel="% of Spend" Style="text-align:right">@context.PctOfSpend%</MudTd>
                    <MudTd DataLabel="Transactions" Style="text-align:right">@context.Count</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTFootRow Class="bold-footer">
                        <MudTd>Total</MudTd>
                        <MudTd Style="text-align:right">@_categories.Sum(r => r.Total).ToString("C")</MudTd>
                        <MudTd Style="text-align:right">100%</MudTd>
                        <MudTd Style="text-align:right">@_categories.Sum(r => r.Count)</MudTd>
                    </MudTFootRow>
                </FooterContent>
            </MudTable>
        </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Pivot" OnClick="() => SetTab(2)">
        @if (_pivot != null)
        {
            <MudTable Items="@_pivot.Rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Month</MudTh>
                    @foreach (var cat in _pivot.Categories)
                    {
                        <MudTh Style="text-align:right" title="@cat">
                            @(cat.Length > 12 ? cat[..11] + "…" : cat)
                        </MudTh>
                    }
                    <MudTh Style="text-align:right">Total</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Month">@context.Label</MudTd>
                    @for (int i = 0; i < context.Values.Count; i++)
                    {
                        var val = context.Values[i];
                        <MudTd DataLabel="@_pivot.Categories[i]" Style="text-align:right">
                            @(val == 0 ? "—" : val.ToString("C"))
                        </MudTd>
                    }
                    <MudTd DataLabel="Total" Style="text-align:right; font-weight:bold">@context.RowTotal.ToString("C")</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTFootRow Class="bold-footer">
                        <MudTd>Total</MudTd>
                        @foreach (var ct in _pivot.ColumnTotals)
                        {
                            <MudTd Style="text-align:right">@ct.ToString("C")</MudTd>
                        }
                        <MudTd Style="text-align:right">@_pivot.GrandTotal.ToString("C")</MudTd>
                    </MudTFootRow>
                </FooterContent>
            </MudTable>
            <MudText Typo="Typo.caption" Class="mt-2">Showing top 8 categories by spend.</MudText>
        }
    </MudTabPanel>

    <MudTabPanel Text="Top Merchants" OnClick="() => SetTab(3)">
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudNumericField @bind-Value="_topN" Label="Top N" Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="100" Style="width:80px" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Refresh">Apply</MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" 
                           Href="@($"api/reports/merchants?year={_year}&topN={_topN}&format=csv")" Target="_blank">
                    Export CSV
                </MudButton>
            </MudStack>
            <MudTable Items="@_merchants" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Merchant</MudTh>
                    <MudTh Style="text-align:right">Total</MudTh>
                    <MudTh Style="text-align:right">Visits</MudTh>
                    <MudTh Style="text-align:right">Avg/Visit</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Merchant">@context.Name</MudTd>
                    <MudTd DataLabel="Total" Style="text-align:right">@context.Total.ToString("C")</MudTd>
                    <MudTd DataLabel="Visits" Style="text-align:right">@context.Count</MudTd>
                    <MudTd DataLabel="Avg/Visit" Style="text-align:right">@context.AvgPerVisit.ToString("C")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Largest" OnClick="() => SetTab(4)">
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudNumericField @bind-Value="_topN" Label="Top N" Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="100" Style="width:80px" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Refresh">Apply</MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" 
                           Href="@($"api/reports/largest?year={_year}&topN={_topN}&format=csv")" Target="_blank">
                    Export CSV
                </MudButton>
            </MudStack>
            <MudTable Items="@_largest" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Merchant</MudTh>
                    <MudTh>Category</MudTh>
                    <MudTh Style="text-align:right">Amount</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.Date.ToString("MMM d, yyyy")</MudTd>
                    <MudTd DataLabel="Merchant">@context.Name</MudTd>
                    <MudTd DataLabel="Category" Class="text-muted">@(string.IsNullOrEmpty(context.Category) ? "—" : context.Category)</MudTd>
                    <MudTd DataLabel="Amount" Style="text-align:right">@context.Amount.ToString("C")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudStack>
    </MudTabPanel>
</MudTabs>

<style>
    .bold-footer td {
        font-weight: bold;
        background-color: var(--mud-palette-background-grey);
    }
</style>

@code {
    private readonly string[] _tabNames = { "Monthly", "By Category", "Pivot", "Top Merchants", "Largest" };
    private int _activeTabIndex = 0;
    private int _year = DateTime.Now.Year;
    private int _topN = 10;
    private bool _loading;
    private string? _error;
    private List<int> _availableYears = new();

    private List<MonthlyRow> _monthly = new();
    private List<CategoryRow> _categories = new();
    private PivotResult? _pivot;
    private List<MerchantRow> _merchants = new();
    private List<TransactionDto> _largest = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadYears();
        await Refresh();
    }

    private async Task LoadYears()
    {
        try
        {
            _availableYears = await Http.GetFromJsonAsync<List<int>>("api/settings/years") ?? new();
            if (_availableYears.Count > 0)
                _year = _availableYears[0];
        }
        catch
        {
            _availableYears = Enumerable.Range(DateTime.Now.Year - 6, 7)
                .OrderByDescending(y => y).ToList();
        }
    }

    private async Task SetTab(int index)
    {
        _activeTabIndex = index;
        await Refresh();
    }

    private async Task OnYearChanged(int year)
    {
        _year = year;
        await Refresh();
    }

    private async Task Refresh()
    {
        _loading = true; _error = null;
        try
        {
            var tabName = _tabNames[_activeTabIndex];
            if (tabName == "Monthly")
                _monthly = await Http.GetFromJsonAsync<List<MonthlyRow>>(
                    $"api/reports/monthly?year={_year}") ?? new();

            else if (tabName == "By Category")
                _categories = await Http.GetFromJsonAsync<List<CategoryRow>>(
                    $"api/reports/category?year={_year}") ?? new();

            else if (tabName == "Pivot")
                _pivot = await Http.GetFromJsonAsync<PivotResult>(
                    $"api/reports/pivot?year={_year}");

            else if (tabName == "Top Merchants")
                _merchants = await Http.GetFromJsonAsync<List<MerchantRow>>(
                    $"api/reports/merchants?year={_year}&topN={_topN}") ?? new();

            else if (tabName == "Largest")
                _largest = await Http.GetFromJsonAsync<List<TransactionDto>>(
                    $"api/reports/largest?year={_year}&topN={_topN}") ?? new();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private record MonthlyRow(string Month, string Label, decimal Total, int Count);
    private record CategoryRow(string Category, decimal Total, int Count, decimal PctOfSpend);
    private record MerchantRow(string Name, decimal Total, int Count, decimal AvgPerVisit);
    private record PivotRow(string Month, string Label, List<decimal> Values, decimal RowTotal);
    private record PivotResult(List<string> Categories, List<PivotRow> Rows,
        decimal GrandTotal, List<decimal> ColumnTotals);
    private record TransactionDto(string TransactionId, string AccountId, DateOnly Date,
        string Name, decimal Amount, string Category);
}
