@page "/csv-import/{AccountId}"
@inject HttpClient Http
@inject NavigationManager Nav

<MudText Typo="Typo.h4" GutterBottom="true">CSV Import</MudText>

@if (!string.IsNullOrEmpty(AccountId))
{
    <MudText Typo="Typo.subtitle1" Class="text-muted mb-4">
        Account: <strong>@AccountId</strong>
    </MudText>
}

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}
@if (_message != null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="my-4">@_message</MudAlert>
}

@if (_step == Step.Upload)
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h6" GutterBottom="true">Step 1: Upload CSV</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">
            Upload a CSV file from your bank. You'll map the columns next.
        </MudText>
        
        <MudStack Spacing="2">
            <InputFile id="fileInput" OnChange="OnFileSelected" accept=".csv" hidden />
            <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload" for="fileInput">
                Select CSV File
            </MudButton>
            
            @if (_uploading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
                <MudText Typo="Typo.caption">Parsing file...</MudText>
            }
        </MudStack>
    </MudPaper>
}

@if (_step == Step.Map && _preview != null)
{
    <MudText Typo="Typo.h6" Class="mt-4 mb-2">Step 2: Map Columns</MudText>

    @if (_missingColumns.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
            The saved mapping is missing columns: <strong>@string.Join(", ", _missingColumns)</strong>.
            Please update the mapping below.
        </MudAlert>
    }

    <MudText Typo="Typo.body2" Class="mb-4">
        Match your CSV columns to CashOut fields. Required: Date, Description, and at least one amount column.
    </MudText>

    <MudPaper Elevation="1" Class="mb-6">
        <MudTable Items="@_preview.Rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Height="200px" FixedHeader="true">
            <HeaderContent>
                @foreach (var h in _preview.Headers)
                {
                    <MudTh>@h</MudTh>
                }
            </HeaderContent>
            <RowTemplate>
                @foreach (var cell in context)
                {
                    <MudTd>@cell</MudTd>
                }
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudPaper Class="pa-6" Elevation="1">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_mapping.DateColumn" Label="Date column *" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">— select —</MudSelectItem>
                    @foreach (var h in _preview.Headers)
                    {
                        <MudSelectItem Value="@h">@h</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_mapping.DescriptionColumn" Label="Description column *" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("")">— select —</MudSelectItem>
                    @foreach (var h in _preview.Headers)
                    {
                        <MudSelectItem Value="@h">@h</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_amountType" Label="Amount type *" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("split")">Separate Credit + Debit columns</MudSelectItem>
                    <MudSelectItem Value="@("single")">Single signed amount column</MudSelectItem>
                </MudSelect>
            </MudItem>
            
            @if (_amountType == "split")
            {
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="_mapping.CreditColumn" Label="Credit column" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@((string?)null)">— none —</MudSelectItem>
                        @foreach (var h in _preview.Headers)
                        {
                            <MudSelectItem Value="@h">@h</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="_mapping.DebitColumn" Label="Debit column" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@((string?)null)">— none —</MudSelectItem>
                        @foreach (var h in _preview.Headers)
                        {
                            <MudSelectItem Value="@h">@h</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            else
            {
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_mapping.AmountColumn" Label="Amount column" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@((string?)null)">— select —</MudSelectItem>
                        @foreach (var h in _preview.Headers)
                        {
                            <MudSelectItem Value="@h">@h</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }

            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_mapping.CategoryColumn" Label="Category column" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@((string?)null)">— none —</MudSelectItem>
                    @foreach (var h in _preview.Headers)
                    {
                        <MudSelectItem Value="@h">@h</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-6" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunImport" Disabled="@_importing" StartIcon="@Icons.Material.Filled.Check">
                @(_importing ? "Importing..." : "Import CSV")
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="() => _step = Step.Upload" StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
        </MudStack>
    </MudPaper>
}

@if (_step == Step.Result && _result != null)
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h6" GutterBottom="true">Import Complete</MudText>
        
        <MudSimpleTable Class="mb-6" Style="max-width:400px">
            <tbody>
                <tr>
                    <td>Rows imported</td>
                    <td style="text-align:right"><strong>@_result.Imported</strong></td>
                </tr>
                <tr>
                    <td>Duplicates skipped</td>
                    <td style="text-align:right">@_result.SkippedDuplicates</td>
                </tr>
                <tr>
                    <td>Other skipped</td>
                    <td style="text-align:right">@_result.SkippedRows.Count</td>
                </tr>
            </tbody>
        </MudSimpleTable>

        @if (_result.SkippedRows.Count > 0)
        {
            <MudExpansionPanels Class="mb-4">
                <MudExpansionPanel Text="@($"{_result.SkippedRows.Count} row(s) skipped — click to review")">
                    <MudTable Items="@_result.SkippedRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>Data</MudTh>
                            <MudTh>Reason</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="#">@context.RowNumber</MudTd>
                            <MudTd DataLabel="Data" Class="text-muted" Style="font-size:0.8em">@context.RawData</MudTd>
                            <MudTd DataLabel="Reason">@context.Reason</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="mt-2" 
                               StartIcon="@Icons.Material.Filled.Download"
                               Href="@($"api/csv-import/{AccountId}/skipped-export")" Target="_blank">
                        Download Skipped Rows CSV
                    </MudButton>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToTransactions" StartIcon="@Icons.Material.Filled.List">
                View Transactions
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="Reset" StartIcon="@Icons.Material.Filled.Refresh">Import Another File</MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string AccountId { get; set; } = "";

    enum Step { Upload, Map, Result }
    Step _step = Step.Upload;

    private CsvPreview? _preview;
    private CsvMappingProfile _mapping = new();
    private string _amountType = "split";
    private ImportResult? _result;
    private List<string> _missingColumns = new();

    private bool _uploading, _importing;
    private string? _csvContent;
    private string? _error, _message;

    protected override async Task OnInitializedAsync()
    {
        // Try to load existing mapping profile
        try
        {
            var profile = await Http.GetFromJsonAsync<CsvMappingProfile>(
                $"api/csv-import/{AccountId}/profile");
            if (profile != null) _mapping = profile;
        }
        catch { /* No profile yet — fine */ }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _uploading = true; _error = null;
        try
        {
            var file = e.File;
            if (file == null) return;

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB
            using var reader = new System.IO.StreamReader(stream);
            _csvContent = await reader.ReadToEndAsync();

            // Preview
            using var form = new MultipartFormDataContent();
            using var content = new StringContent(_csvContent);
            form.Add(new StreamContent(new System.IO.MemoryStream(
                System.Text.Encoding.UTF8.GetBytes(_csvContent))), "file", file.Name);

            var resp = await Http.PostAsync($"api/csv-import/{AccountId}/preview", form);
            resp.EnsureSuccessStatusCode();
            _preview = await resp.Content.ReadFromJsonAsync<CsvPreview>();

            // Check if saved mapping is still valid
            if (_mapping.DateColumn != "")
            {
                var headers = _preview?.Headers ?? Array.Empty<string>();
                _missingColumns = _mapping.MappedColumns()
                    .Where(col => !headers.Select(h => h.ToLowerInvariant()).Contains(col))
                    .ToList();
            }

            // Detect amount type from saved mapping
            if (!string.IsNullOrEmpty(_mapping.AmountColumn))
                _amountType = "single";

            _step = Step.Map;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _uploading = false; }
    }

    private async Task RunImport()
    {
        if (_csvContent == null) return;
        _importing = true; _error = null;

        // Apply amount type
        if (_amountType == "single")
        {
            _mapping.CreditColumn = null;
            _mapping.DebitColumn = null;
        }
        else
        {
            _mapping.AmountColumn = null;
        }

        try
        {
            // Save mapping profile
            await Http.PostAsJsonAsync($"api/csv-import/{AccountId}/profile", _mapping);

            // Run import
            using var form = new MultipartFormDataContent();
            form.Add(new StreamContent(new System.IO.MemoryStream(
                System.Text.Encoding.UTF8.GetBytes(_csvContent))), "file", "import.csv");

            var resp = await Http.PostAsync($"api/csv-import/{AccountId}/import", form);
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                _error = err?["error"] ?? "Import failed.";
                return;
            }

            _result = await resp.Content.ReadFromJsonAsync<ImportResult>();
            _step = Step.Result;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _importing = false; }
    }

    private void GoToTransactions()
    {
        Nav.NavigateTo("/transactions");
    }


    private void Reset()
    {
        _step = Step.Upload;
        _preview = null;
        _result = null;
        _csvContent = null;
        _error = null;
        _message = null;
        _missingColumns.Clear();
    }

    // Local mirror of server types for JSON deserialization
    private record CsvPreview(string[] Headers, string[][] Rows);
    private record SkippedRow(int RowNumber, string RawData, string Reason);
    private record ImportResult(int Imported, int SkippedDuplicates, List<SkippedRow> SkippedRows);
}
