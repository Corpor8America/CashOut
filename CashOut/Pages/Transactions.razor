@page "/transactions"
@using System.Globalization
@inject HttpClient Http
@inject NavigationManager Nav

<MudText Typo="Typo.h4" GutterBottom="true">Transactions</MudText>

@if (_filterAccountName != null)
{
    <MudPaper Elevation="1" Class="mb-4 pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body1">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-2" />
                Showing transactions for <strong>@_filterAccountName</strong>
            </MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ClearAccountFilter"
                       StartIcon="@Icons.Material.Filled.Close">
                Show all
            </MudButton>
        </MudStack>
    </MudPaper>
}

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">@_error</MudAlert>
}
@if (_message != null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="my-4">@_message</MudAlert>
}

@* ── Year + Month tabs row ── *@
<MudPaper Elevation="1" Class="mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="px-4 pt-3 pb-0">
        <MudSelect T="int" Label="Year" Value="_filterYear" ValueChanged="OnYearChangedInternal" Dense="true"
                   Margin="Margin.Dense" Style="width:90px; flex-shrink:0" Variant="Variant.Outlined">
            @foreach (var y in _availableYears)
            {
                <MudSelectItem Value="@y">@y</MudSelectItem>
            }
        </MudSelect>

        <MudTabs Elevation="0" Rounded="false" Color="Color.Primary" ActivePanelIndex="@_activeMonthTabIndex"
                 Class="flex-grow-1" Style="min-width:0" ActivePanelIndexChanged="OnActiveMonthChanged">
            @for (int m = 1; m <= 12; m++)
            {
                var monthIndex = m;
                <MudTabPanel Text="@CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(m)" />
            }
        </MudTabs>

        @* Category filter icon *@
        <div style="position: relative;">
            <MudTooltip Text="Filter by category">
                <MudBadge Content="@(_selectedCategories.Count > 0 ? _selectedCategories.Count.ToString() : null)"
                          Color="Color.Primary" Overlap="true" Visible="@(_selectedCategories.Count > 0)">
                    <MudIconButton Icon="@Icons.Material.Filled.FilterList"
                                   Color="@(_selectedCategories.Count > 0 ? Color.Primary : Color.Default)"
                                   OnClick="ToggleCategoryFilter" id="cat-filter-btn" />
                </MudBadge>
            </MudTooltip>

            @* ── Category filter popover ── *@
            <MudPopover Open="_categoryPopoverOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <MudPaper Elevation="4" Style="width:260px; padding:12px">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Filter by Category</MudText>

                    @if (_categories.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No categories available.</MudText>
                    }
                    else
                    {
                        <div style="max-height:260px; overflow-y:auto; margin-bottom:8px">
                            @foreach (var cat in _categories)
                            {
                                var isCat = cat; @* capture for lambda *@
                                <MudCheckBox T="bool" Value="@_pendingCategories.Contains(isCat)"
                                             ValueChanged="@(v => ToggleCategorySelection(isCat, v))" Label="@isCat" Dense="true"
                                             Color="Color.Primary" />
                            }
                        </div>
                    }

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="ApplyCategoryFilter">
                            Apply</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ClearCategoryFilter">Clear</MudButton>
                    </MudStack>
                </MudPaper>
            </MudPopover>
        </div>
    </MudStack>
</MudPaper>

    @* ── Month summary ── *@
    @if (_summaryLoading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mt-2" />
    }
    else if (_categorySummary.Count > 0)
    {
        <MudExpansionPanels Elevation="1" Class="mb-6">
            <MudExpansionPanel Text="Month Summary" Expanded="true">
                <MudSimpleTable Dense="true" Hover="true" Elevation="0" Style="width:100%">
                    <thead>
                        <tr>
                            <th style="width:40%">Category</th>
                            <th style="width:30%; text-align:right">Month Total (Net)</th>
                            <th style="width:30%; text-align:right">12 Mo Avg (Net)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var context in _categorySummary.OrderBy(s => s.Category))
                        {
                            if (context.MonthNet == 0 && context.MonthCredit == 0 && context.MonthDebit == 0)
                                continue;

                            <tr>
                                <td>@context.Category</td>
                                <td style="text-align:right">
                                    <span style="color:@(context.MonthNet < 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")">
                                        @FormatCurrency(context.MonthNet)
                                    </span>
                                </td>
                                <td style="text-align:right">
                                    <span style="color:@(context.AvgNet < 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")">
                                        @FormatCurrency(context.AvgNet)
                                    </span>
                                </td>
                            </tr>
                        }

                        @{
                            var mDebit = _categorySummary.Sum(s => s.MonthDebit);
                            var mCredit = _categorySummary.Sum(s => s.MonthCredit);
                            var mNet = mCredit - mDebit;
                            var aDebit = _categorySummary.Sum(s => s.AvgDebit);
                            var aCredit = _categorySummary.Sum(s => s.AvgCredit);
                            var aNet = aCredit - aDebit;
                        }
                        <tr class="footer-row-secondary">
                            <td class="mud-table-cell">Credit Total</td>
                            <td class="mud-table-cell" style="text-align:right; color:var(--mud-palette-success)">@mCredit.ToString("C")</td>
                            <td class="mud-table-cell" style="text-align:right; color:var(--mud-palette-success)">@aCredit.ToString("C")</td>
                        </tr>
                        <tr class="footer-row-secondary">
                            <td class="mud-table-cell">Debit Total</td>
                            <td class="mud-table-cell" style="text-align:right; color:var(--mud-palette-error)">-@mDebit.ToString("C")</td>
                            <td class="mud-table-cell" style="text-align:right; color:var(--mud-palette-error)">-@aDebit.ToString("C")</td>
                        </tr>
                        <tr class="footer-row-main">
                            <td class="mud-table-cell">Net Total</td>
                            <td class="mud-table-cell" style="text-align:right">
                                <span style="color:@(mNet < 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")">
                                    @FormatCurrency(mNet)
                                </span>
                            </td>
                            <td class="mud-table-cell" style="text-align:right">
                                <span style="color:@(aNet < 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)")">
                                    @FormatCurrency(aNet)
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    <style>
        .footer-row-secondary .mud-table-cell {
            font-size: 0.875rem;
            font-weight: 500;
            background-color: var(--mud-palette-background-grey);
            color: var(--mud-palette-text-secondary);
            border: none !important;
        }

        .footer-row-main .mud-table-cell {
            font-size: 1rem;
            font-weight: 700;
            background-color: var(--mud-palette-background-grey);
            border-top: 2px solid var(--mud-palette-divider) !important;
        }
    </style>

    @* ── Transaction list ── *@
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (_transactions.Count == 0)
    {
        <MudText Color="Color.Secondary" Class="mt-4">No transactions found for this month/filter.</MudText>
    }
    else
    {
        <MudTable Items="@_transactions" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1" Dense="true" Class="mt-2">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Merchant</MudTh>
                <MudTh>Category</MudTh>
                <MudTh Style="text-align:right">Amount</MudTh>
            </HeaderContent>
            <RowTemplate>
                @{
                    var isCredit = context.Credit.HasValue;
                    var displayAmount = isCredit ? context.Credit!.Value : (context.Debit ?? 0);
                }
                <MudTd DataLabel="Date">@context.Date.ToString("MMM d, yyyy")</MudTd>
                <MudTd DataLabel="Merchant">@context.Name</MudTd>
                <MudTd DataLabel="Category">
                    @if (_editingId == context.TransactionId)
                    {
                        <div style="display:flex;gap:0.35rem;align-items:center">
                            <MudTextField T="string" Value="@_editValue" ValueChanged="@(v => _editValue = v)"
                                          OnKeyDown="@(e => OnEditKey(e, context.TransactionId))" Margin="Margin.Dense"
                                          Variant="Variant.Outlined" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                           OnClick="() => CommitEdit(context.TransactionId)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                           OnClick="CancelEdit" />
                        </div>
                    }
                    else
                    {
                        <span @ondblclick="() => StartEdit(context.TransactionId, context.Category)" title="Double-click to edit"
                              style="cursor:pointer;display:inline-block;min-width:60px;
                            border-bottom:1px dashed #ccc;padding-bottom:1px">
                            @(string.IsNullOrEmpty(context.Category) ? "—" : context.Category)
                        </span>
                    }
                </MudTd>
                <MudTd DataLabel="Amount" Style="text-align:right">
                    <MudText Color="@(isCredit ? Color.Success : Color.Error)" Style="font-weight:bold">
                        @displayAmount.ToString("C")
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

@code {
    private List<TransactionDto> _transactions = new();
    private List<string> _categories = new();
    private List<int> _availableYears = new();
    private List<CategorySummaryDto> _categorySummary = new();

    private int _filterYear = DateTime.Now.Year;
    private int _filterMonth = DateTime.Now.Month;
    private int _activeMonthTabIndex;

    // Multi-select category filter state
    private HashSet<string> _selectedCategories = new();
    private HashSet<string> _pendingCategories = new(); // tracks in-popover selection before Apply
    private bool _categoryPopoverOpen;

    private bool _loading, _summaryLoading;
    private string? _error, _message;

    // Account filter
    private string? _filterAccountId;
    private string? _filterAccountName;

    // Inline category edit
    private string? _editingId;
    private string _editValue = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        _filterAccountId = System.Web.HttpUtility.ParseQueryString(uri.Query)["accountId"];
        _filterAccountName = System.Web.HttpUtility.ParseQueryString(uri.Query)["accountName"];

        _activeMonthTabIndex = _filterMonth - 1;
        await LoadYears();
        await LoadTransactions();
        await LoadSummary();
    }

    // ── Year / Month ──────────────────────────────────────────────────────

    private async Task LoadYears()
    {
        try
        {
            _availableYears = await Http.GetFromJsonAsync<List<int>>("api/settings/years") ?? new();
            if (_availableYears.Count > 0)
                _filterYear = _availableYears[0];
        }
        catch
        {
            _availableYears = Enumerable.Range(DateTime.Now.Year - 6, 7)
                .OrderByDescending(y => y).ToList();
        }
    }

    private async Task OnYearChangedInternal(int year)
    {
        _filterYear = year;
        _selectedCategories.Clear();
        _pendingCategories.Clear();
        await LoadAllCategories();
        await LoadTransactions();
        await LoadSummary();
    }

    private async Task OnActiveMonthChanged(int newIndex)
    {
        // newIndex is 0-indexed, so add 1 to get the actual month number (1-12)
        var newMonth = newIndex + 1;

        // Only proceed if the month has actually changed to prevent unnecessary reloads
        if (_filterMonth == newMonth) return;

        _filterMonth = newMonth;

        await LoadTransactions();
        await LoadSummary();
    }

    // ── Category filter popover ───────────────────────────────────────────

    private void ToggleCategoryFilter()
    {
        if (!_categoryPopoverOpen)
            // seed pending with current selection when opening
            _pendingCategories = new HashSet<string>(_selectedCategories);
        _categoryPopoverOpen = !_categoryPopoverOpen;
    }

    private void ToggleCategorySelection(string category, bool selected)
    {
        if (selected) _pendingCategories.Add(category);
        else _pendingCategories.Remove(category);
    }

    private async Task ApplyCategoryFilter()
    {
        _selectedCategories = new HashSet<string>(_pendingCategories);
        _categoryPopoverOpen = false;
        await LoadTransactions();
    }

    private async Task ClearCategoryFilter()
    {
        _pendingCategories.Clear();
        _selectedCategories.Clear();
        _categoryPopoverOpen = false;
        await LoadTransactions();
    }

    private async Task ClearAccountFilter()
    {
        _filterAccountId = null;
        _filterAccountName = null;
        _selectedCategories.Clear();
        _pendingCategories.Clear();
        await LoadTransactions();
        await LoadSummary();
    }

    // ── Data loading ──────────────────────────────────────────────────────

    private async Task LoadTransactions()
    {
        _loading = true; _error = null;
        try
        {
            var url = $"api/transactions?year={_filterYear}&month={_filterMonth}";

            if (!string.IsNullOrEmpty(_filterAccountId))
                url += $"&accountId={Uri.EscapeDataString(_filterAccountId)}";

            // Pass each selected category as a repeated query param;
            // if none selected, no category filter is applied
            foreach (var cat in _selectedCategories)
                url += $"&category={Uri.EscapeDataString(cat)}";

            _transactions = await Http.GetFromJsonAsync<List<TransactionDto>>(url) ?? new();

            if (_categories.Count == 0)
                await LoadAllCategories();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task LoadSummary()
    {
        _summaryLoading = true;
        try
        {
            var url = $"api/reports/category-summary?year={_filterYear}&month={_filterMonth}";
            if (!string.IsNullOrEmpty(_filterAccountId))
                url += $"&accountId={Uri.EscapeDataString(_filterAccountId)}";
            _categorySummary = await Http.GetFromJsonAsync<List<CategorySummaryDto>>(url) ?? new();
        }
        catch { /* ignored */ }
        finally { _summaryLoading = false; }
    }

    private async Task LoadAllCategories()
    {
        try
        {
            var url = $"api/transactions?year={_filterYear}";
            if (!string.IsNullOrEmpty(_filterAccountId))
                url += $"&accountId={Uri.EscapeDataString(_filterAccountId)}";
            var all = await Http.GetFromJsonAsync<List<TransactionDto>>(url) ?? new();
            _categories = all
                .Select(t => t.Category)
                .Where(c => !string.IsNullOrEmpty(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList();
        }
        catch { /* ignored */ }
    }

    // ── Inline category edit ──────────────────────────────────────────────

    private void StartEdit(string transactionId, string currentCategory)
    {
        _editingId = transactionId;
        _editValue = currentCategory;
        _message = null;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editValue = "";
    }

    private async Task CommitEdit(string transactionId)
    {
        if (_editingId != transactionId) return;

        var newCategory = _editValue.Trim();
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/transactions/{Uri.EscapeDataString(transactionId)}/category",
                new { Category = newCategory });
            resp.EnsureSuccessStatusCode();

            var txn = _transactions.FirstOrDefault(t => t.TransactionId == transactionId);
            if (txn != null)
            {
                var idx = _transactions.IndexOf(txn);
                _transactions[idx] = txn with { Category = newCategory };
            }

            if (!_categories.Contains(newCategory) && !string.IsNullOrEmpty(newCategory))
            {
                _categories.Add(newCategory);
                _categories = _categories.OrderBy(c => c).ToList();
            }

            await LoadSummary();
        }
        catch (Exception ex) { _error = $"Failed to update category: {ex.Message}"; }
        finally { CancelEdit(); }
    }

    private async Task OnEditKey(KeyboardEventArgs e, string transactionId)
    {
        if (e.Key == "Enter") await CommitEdit(transactionId);
        else if (e.Key == "Escape") CancelEdit();
    }

    // ── DTOs ──────────────────────────────────────────────────────────────

    private record TransactionDto(
        string TransactionId,
        string AccountId,
        DateOnly Date,
        string Name,
        decimal? Credit,
        decimal? Debit,
        decimal Amount,
        string Category
    );

    private record CategorySummaryDto(
        string Category,
        decimal MonthDebit,
        decimal MonthCredit,
        decimal MonthNet,
        decimal AvgNet,
        decimal AvgDebit,
        decimal AvgCredit);

    /// <summary>Formats a currency value with a leading minus sign for negatives, no '+' sign for positives.</summary>
    private string FormatCurrency(decimal value)
    {
        if (value < 0)
            return $"-{Math.Abs(value).ToString("C")}";
        return value.ToString("C");
    }
}
